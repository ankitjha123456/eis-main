#!/bin/bash

SERVERS=(
    "10.177.44.71"
    "10.177.44.72"
    "10.177.44.73"
    "10.177.44.74"
)

PORT="8002"
ENDPOINT="/cacheOnDB"

# Associative array to store responses
declare -A RESULTS

# Launch all in parallel using subshells with pipe trick
for server in "${SERVERS[@]}"; do
    (
        response=$(su - eisuser -c \
            "ssh -o StrictHostKeyChecking=no \
                 -o ConnectTimeout=10 \
                 -o BatchMode=yes \
                 ${server} \
                 \"curl --silent --location 'http://localhost:${PORT}${ENDPOINT}' \
                   -H 'Content-Type: application/json' \
                   -d '{\\\"UPDATE\\\":\\\"Y\\\"}' \"" 2>/dev/null)

        cache_val=$(echo "$response" | sed 's/.*"CACHE RESPONSE":"\([^"]*\)".*/\1/')

        echo "${server}|${cache_val}"
    ) &
done | while IFS='|' read -r server cache_val; do
    RESULTS["$server"]="$cache_val"
done

wait

# Print final JSON array
echo "["
total=${#SERVERS[@]}
for i in "${!SERVERS[@]}"; do
    server="${SERVERS[$i]}"
    comma=","
    [ $((i + 1)) -eq $total ] && comma=""
    echo "  {\"server\":\"${server}\",\"CACHE RESPONSE\":\"${RESULTS[$server]}\"}${comma}"
done
echo "]"