#!/bin/bash

# Runs as root -> su eisuser -> ssh to each server -> curl localhost

SERVERS=(
    "10.177.44.71"
    "10.177.44.72"
    "10.177.44.73"
    "10.177.44.74"
)

PORT="8002"
ENDPOINT="/cacheOnDB"
PAYLOAD='{"UPDATE":"Y"}'

echo "["

total=${#SERVERS[@]}
for i in "${!SERVERS[@]}"; do
    server="${SERVERS[$i]}"

    response=$(su - eisuser -c \
        "ssh -o StrictHostKeyChecking=no \
             -o ConnectTimeout=10 \
             -o BatchMode=yes \
             ${server} \
             \"curl --silent --location 'http://localhost:${PORT}${ENDPOINT}' \
               -H 'Content-Type: application/json' \
               -d '{\\\"UPDATE\\\":\\\"Y\\\"}' \"" 2>/dev/null)

    escaped_response=$(echo "$response" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr -d '\n')

    comma=","
    [ $((i + 1)) -eq $total ] && comma=""

    echo "  {"
    echo "    \"server\": \"${server}\","
    echo "    \"cache_response\": \"${escaped_response}\""
    echo "  }${comma}"

done

echo "]"