#!/bin/bash

if [ "$#" -ne 4 ]; then
    echo "Usage: $0 <server> <broker> <eg_name> <service_name>"
    exit 1
fi

server=$1
broker=$2
eg=$3
service=$4

REMOTE_PATH="/var/mqsi/components/${broker}/servers/${eg}/run/${service}"

su - eisuser -c "ssh -tq eisuser@$server '
cd $REMOTE_PATH || { echo \"<error>Path not found</error>\"; exit 1; }

echo \"<validationFiles>\"

# Check for .xsd files in current directory first, then fall back to gen/
shopt -s nullglob
xsd_files=(*.xsd)

if [ \${#xsd_files[@]} -eq 0 ]; then
    if [ -d \"gen\" ]; then
        cd gen || { echo \"<error>Cannot enter gen directory</error>\"; exit 1; }
        xsd_files=(*.xsd)
    fi
fi

if [ \${#xsd_files[@]} -eq 0 ]; then
    echo \"<error>No validation files found</error>\"
    echo \"</validationFiles>\"
    exit 1
fi

for file in \"\${xsd_files[@]}\"; do
    echo \"  <Validation>\"
    echo \"    <fileName>\$file</fileName>\"
    echo \"    <fileContent><![CDATA[\"
    cat \"\$file\"
    echo \"    ]]></fileContent>\"
    echo \"  </Validation>\"
done

echo \"</validationFiles>\"
'"