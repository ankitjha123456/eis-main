stages:
# ================= CACHE STAGE =================
  - stage: Cache
    displayName: CACHE
    pool:
      name: TFS-RH-1

    jobs:
      - job: Cache_Job
        displayName: CACHE UPDATE
        workspace:
          clean: all

        steps:

          # ✅ Checkout the shared/template repo (azure-pipelines)
          - checkout: self
            path: s/shared

          # ✅ Checkout the calling repo (cache-pipeline) where cache.yml lives
          - checkout: git://YOUR_PROJECT/cache-pipeline@refs/heads/main
            path: s/cache-pipeline

          - task: CmdLine@2
            displayName: Update cache in Database
            env:
              BRANCH: $(Build.SourceBranchName)
            inputs:
              workingDirectory: $(Agent.BuildDirectory)/s/cache-pipeline   # ✅ point to cache-pipeline
              script: |
                source ~/.bashrc
                set -e

                if [ ! -f cache.yml ]; then
                  echo "cache.yml file was not found !!"
                  exit 1
                fi

                yq -r ".Cache[].Query" cache.yml | while IFS= read -r SQL; do
                  echo "Executing SQL: $SQL"
                  OUTPUT=$(echo "$SQL" | isql "$BRANCH" "$DB_USER" "$DB_PASS" 2>&1)
                  STATUS=$?
                  if [[ $STATUS -eq 0 ]] && echo "$OUTPUT" | grep -qi "SQLRowCount"; then
                    echo "SUCCESS: Query executed"
                  else
                    echo "FAILED: Query did not execute"
                    echo "Output: $OUTPUT"
                    exit 1
                  fi
                done

          - task: CmdLine@2
            displayName: Update Cache in Server
            env:
              BRANCH: $(Build.SourceBranchName)
            inputs:
              workingDirectory: $(Agent.BuildDirectory)/s/cache-pipeline   # ✅ point to cache-pipeline
              script: |
                set -e

                if [ ! -f cache.yml ]; then
                  echo "cache.yml file was not found !!"
                  exit 1
                fi

                IntegrationNode=($(yq e ".IntegrationNode" cache.yml))
                broker_files=()

                for node in "${IntegrationNode[@]}"; do
                  for broker_file in /home/devops/broker/$BRANCH/${node}*; do
                    fname=$(basename "$broker_file")
                    if [[ $fname =~ ^${node}_([0-9]+)\.broker$ ]]; then
                      broker_files+=("$broker_file")
                    fi
                  done
                done

                if [ ${#broker_files[@]} -eq 0 ]; then
                  echo "Error: No Integration Node found for $IntegrationNode"
                  exit 1
                fi

                for broker_file in "${broker_files[@]}"; do
                  host=$(cat "$broker_file" | grep host | cut -d"\"" -f4)
                  if yq -e ".Cache" cache.yml >/dev/null 2>&1; then
                    response=$(curl --connect-timeout 3 --max-time 5 -s -k -X POST http://"$host":8002/cache/v1/loadCache \
                      -H "Content-Type: application/json" \
                      -d "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" cache.yml)")
                    if [[ "$response" != *'"RESPONSE":"success"'* ]]; then
                      echo "Cache load failed: $response"
                      exit 1
                    fi
                    echo "Cache load successful on $host"
                    echo "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" cache.yml)"
                  fi
                done