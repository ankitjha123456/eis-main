// ══════════ DB / ACE ══════════
function dbQuickFill(el,_){
  document.querySelectorAll('#pdb .sb-it').forEach(i=>i.classList.remove('on'));
  el.classList.add('on');
  try{ const d=JSON.parse(el.dataset.f||'{}'); Object.entries(d).forEach(([k,v])=>{ const e=document.getElementById(k);if(e)e.value=v; }); }catch(e){}
