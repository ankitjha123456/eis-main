server {
    listen 4415;
    server_name 10.177.44.29;

    root /usr/share/nginx/html;

    # index.html at /
    location / {
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # index1.html at /gen6ui (renamed to avoid clashing with the API path below)
    location /gen6ui {
        alias /usr/share/nginx/html/gen6ui;
        index index1.html;
        try_files $uri $uri/ /gen6ui/index1.html;
    }

    # your existing API proxy — unchanged
    location /EISdev/ {
        proxy_pass http://10.177.44.22:4002/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}