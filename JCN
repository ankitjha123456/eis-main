server {
    listen 4415;
    server_name 10.177.44.29;

    root /usr/share/nginx/html;

    # Root page
    location / {
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # EISdev static page
    location /EISdev/ {
        alias /usr/share/nginx/html/EISdev/;
        index index.html;
        try_files $uri $uri/ =404;
    }

    # DBQUERY static page
    location /DBQUERY/ {
        alias /usr/share/nginx/html/DBQUERY/;
        index index.html;
        try_files $uri $uri/ =404;
    }

    # API proxy — separate path, no clash with /EISdev/
    location /api/ {
        proxy_pass http://10.177.44.22:4002/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}