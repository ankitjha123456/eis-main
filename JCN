// Detect whether a DOM node in the XSD sits inside a Request (TX) or Response (RX)
// definition, by walking up for the nearest ancestor name containing those hints.
function xsdDirectionOfNode(el){
  let node=el;
  while(node&&node.getAttribute){
    const name=node.getAttribute('name');
    if(name){
      if(/request|req\b|_req$|\btx\b/i.test(name))return'TX';
      if(/response|resp\b|_resp$|\brx\b/i.test(name))return'RX';
    }
    node=node.parentElement;
  }
  return'TX';
}
// Same idea but for the regex-fallback path, where we only have raw text + an offset.
function xsdDirectionAt(xsd,pos){
  const head=xsd.slice(0,pos);
  const rx=/<[\w]*:?(?:complexType|element)\b[^>]*name="([^"]+)"/g;
  let m,last=null;
  while((m=rx.exec(head))!==null)last=m[1];
  if(last){
    if(/request|req\b|_req$|\btx\b/i.test(last))return'TX';
    if(/response|resp\b|_resp$|\brx\b/i.test(last))return'RX';
  }
  return'TX';
}

// Real XSD parser — uses the browser's DOMParser + real namespace resolution, so it works
// no matter which prefix the schema uses (xs:, xsd:, a custom prefix, or no prefix at all).
// Also extracts description (xs:documentation), maxLength, and the required cardinality
// expressed as "minOccurs,maxOccurs" (e.g. "1,1" = required, "0,1" = not required).
const XSD_NS='http://www.w3.org/2001/XMLSchema';
function parseXSD(xsd){
  if(!xsd||!xsd.trim())return[];
  let doc=null;
  try{
    doc=new DOMParser().parseFromString(xsd,'application/xml');
    if(doc.getElementsByTagName('parsererror').length)doc=null;
  }catch(e){doc=null;}

  if(doc){
    const fields=[];
    const seen=new Set();
    const elements=doc.getElementsByTagNameNS(XSD_NS,'element');
    for(let i=0;i<elements.length;i++){
      const el=elements[i];
      const name=el.getAttribute('name');
      if(!name||seen.has(name))continue;
      seen.add(name);
      const type=el.getAttribute('type')||'xs:string';
      const min=el.hasAttribute('minOccurs')?el.getAttribute('minOccurs'):'1';
      const maxRaw=el.hasAttribute('maxOccurs')?el.getAttribute('maxOccurs'):'1';
      const max=maxRaw==='unbounded'?'unbounded':maxRaw;
      let description='';
      const docEl=el.getElementsByTagNameNS(XSD_NS,'documentation')[0];
      if(docEl)description=(docEl.textContent||'').trim();
      let length='';
      const restr=el.getElementsByTagNameNS(XSD_NS,'restriction')[0];
      if(restr){
        const ml=restr.getElementsByTagNameNS(XSD_NS,'maxLength')[0];
        if(ml)length=ml.getAttribute('value')||'';
      }
      fields.push({
        name,xsdType:type,oapiType:xsdToOapi(type),format:xsdFormat(type),
        required:min!=='0',
        minOccurs:min,maxOccurs:max,
        cardinality:`${min},${max}`,
        isArray:max==='unbounded'||parseInt(max||'1',10)>1,
        description,
        length,
        direction:xsdDirectionOfNode(el)
      });
    }
    const attrs=doc.getElementsByTagNameNS(XSD_NS,'attribute');
    for(let i=0;i<attrs.length;i++){
      const el=attrs[i];
      const name=el.getAttribute('name');
      if(!name||seen.has(name))continue;
      seen.add(name);
      const type=el.getAttribute('type')||'xs:string';
      const use=el.getAttribute('use');
      const required=use==='required';
      let length='';
      const restr=el.getElementsByTagNameNS(XSD_NS,'restriction')[0];
      if(restr){
        const ml=restr.getElementsByTagNameNS(XSD_NS,'maxLength')[0];
        if(ml)length=ml.getAttribute('value')||'';
      }
      fields.push({
        name,xsdType:type,oapiType:xsdToOapi(type),format:xsdFormat(type),
        required,minOccurs:required?'1':'0',maxOccurs:'1',cardinality:required?'1,1':'0,1',
        isArray:false,description:'',length,
        direction:xsdDirectionOfNode(el)
      });
    }
    if(fields.length)return fields;
    // DOMParser succeeded but found zero elements/attributes (e.g. odd structure) —
    // fall through to the regex fallback below just in case.
  }

  // ── Fallback tokenizer: only used if the XML failed to parse or DOMParser found nothing
  // (e.g. minor well-formedness issues in a real-world enterprise XSD). This walks tags in a
  // single linear pass with a real stack, so — unlike a naive regex — it correctly tells leaf
  // fields (e.g. NEW_PARAM) apart from container/complexType elements that merely wrap other
  // elements (e.g. an outer "AccountRequest" element), regardless of nesting depth or prefix.
  return parseXSDTokenizer(xsd);
}
function parseXSDTokenizer(xsd){
  const tagRe=/<(\/?)([\w.\-]+(?::[\w.\-]+)?)((?:\s+[\w.\-]+(?::[\w.\-]+)?\s*=\s*"[^"]*")*)\s*(\/?)\s*>/g;
  const localName=t=>t.includes(':')?t.split(':').pop():t;
  function attrsToObj(s){
    const o={};const ar=/([\w.\-]+(?::[\w.\-]+)?)\s*=\s*"([^"]*)"/g;let am;
    while((am=ar.exec(s))!==null)o[am[1].includes(':')?am[1].split(':').pop():am[1]]=am[2];
    return o;
  }
  const fields=[];
  const seen=new Set();
  const stack=[]; // {tagName, local, attrs, hasElementChild, contentStart}
  function dirFromStack(){
    for(let i=stack.length-1;i>=0;i--){
      const nm=stack[i].attrs.name;
      if(nm){
        if(/request|req\b|_req$|\btx\b/i.test(nm))return'TX';
        if(/response|resp\b|_resp$|\brx\b/i.test(nm))return'RX';
      }
    }
    return'TX';
  }
  function emit(local,attrs,innerText){
    const name=attrs.name;
    if(!name||seen.has(name))return;
    if(local==='attribute'){
      seen.add(name);
      const type=attrs.type||'xs:string';
      const required=attrs.use==='required';
      fields.push({
        name,xsdType:type,oapiType:xsdToOapi(type),format:xsdFormat(type),
        required,minOccurs:required?'1':'0',maxOccurs:'1',cardinality:required?'1,1':'0,1',
        isArray:false,description:'',length:attrs.maxLength||'',direction:dirFromStack()
      });
      return;
    }
    // local === 'element'
    seen.add(name);
    const type=attrs.type||'xs:string';
    const min=attrs.minOccurs!==undefined?attrs.minOccurs:'1';
    const maxRaw=attrs.maxOccurs!==undefined?attrs.maxOccurs:'1';
    const max=maxRaw==='unbounded'?'unbounded':maxRaw;
    const docMatch=innerText&&(innerText.match(/<[\w.\-]*:?documentation[^>]*>([\s\S]*?)<\/[\w.\-]*:?documentation>/)||[])[1];
    const maxLen=innerText&&((innerText.match(/maxLength[^>]*value="([^"]+)"/)||[])[1])||attrs.maxLength||'';
    fields.push({
      name,xsdType:type,oapiType:xsdToOapi(type),format:xsdFormat(type),
      required:min!=='0',minOccurs:min,maxOccurs:max,
      cardinality:`${min},${max}`,
      isArray:max==='unbounded'||parseInt(max||'1',10)>1,
      description:docMatch?docMatch.trim():'',
      length:maxLen,
      direction:dirFromStack()
    });
  }
  function markNearestElementAncestor(stack){
    for(let i=stack.length-1;i>=0;i--){
      if(stack[i].local==='element'){stack[i].hasElementChild=true;return;}
    }
  }
  let m;
  while((m=tagRe.exec(xsd))!==null){
    const closing=m[1]==='/';
    const tagName=m[2];
    const local=localName(tagName);
    const selfClose=m[4]==='/';
    if(closing){
      // Pop until we find the matching open tag (tolerant of any stray/mismatched tags).
      for(let i=stack.length-1;i>=0;i--){
        if(stack[i].tagName===tagName){
          const node=stack.splice(i)[0];
          if((local==='element'||local==='attribute')&&!node.hasElementChild){
            emit(local,node.attrs,xsd.slice(node.contentStart,m.index));
          }
          break;
        }
      }
      continue;
    }
    const attrs=attrsToObj(m[3]);
    if(selfClose){
      if(local==='element'||local==='attribute')emit(local,attrs,'');
      if(local==='element')markNearestElementAncestor(stack);
      continue;
    }
    // Regular opening tag
    if(local==='element')markNearestElementAncestor(stack);
    stack.push({tagName,local,attrs,hasElementChild:false,contentStart:tagRe.lastIndex});
  }
  return fields;
}
function xsdToOapi(t){
  if(!t)return'string';
  if(/int|integer|long|short|byte/.test(t))return'integer';
  if(/decimal|float|double/.test(t))return'number';
  if(/boolean/.test(t))return'boolean';
  return'string';
}
function xsdFormat(t){
  if(/dateTime/.test(t))return'date-time';
  if(/date$/.test(t))return'date';
  if(/time$/.test(t))return'time';
  if(/email/.test(t))return'email';
  if(/uri|url/.test(t))return'uri';
  return null;
}

// Real YAML field extractor
// Real Swagger/OpenAPI parser — parses actual JSON or YAML content (no more static/regex guessing).
// Returns: fields (unique field names anywhere in schemas/bodies), paths (real path keys),
// fieldDirs (map fieldName -> 'TX'|'RX'|'BOTH' based on where it was found), and the raw parsed object.
function parseYAML(raw){
  if(!raw||!raw.trim())return{fields:[],paths:[],fieldDirs:{},spec:null,parseError:null};
  let spec=null,parseError=null;
  const trimmed=raw.trim();
  try{
    if(trimmed[0]==='{'||trimmed[0]==='['){
      spec=JSON.parse(raw);
    }else if(typeof jsyaml!=='undefined'){
      spec=jsyaml.load(raw);
    }else{
      // js-yaml failed to load (e.g. offline) — last resort JSON attempt
      spec=JSON.parse(raw);
    }
  }catch(err){
    parseError=err.message;
  }
  const fields=new Set();
  const fieldDirs={};
  const paths=[];
  function mark(name,dir){
    fields.add(name);
    const lc=name.toLowerCase();
    if(!fieldDirs[lc])fieldDirs[lc]=dir;
    else if(fieldDirs[lc]!==dir)fieldDirs[lc]='BOTH';
  }
  // Recursively walk any node; when we hit a "properties" object, its keys are real schema fields.
  // `dir` tracks whether we are currently inside a request-side or response-side branch.
  function walk(node,dir){
    if(!node||typeof node!=='object')return;
    if(Array.isArray(node)){node.forEach(n=>walk(n,dir));return;}
    Object.entries(node).forEach(([key,val])=>{
      let nextDir=dir;
      if(/^requestbody$/i.test(key))nextDir='TX';
      else if(/^responses$/i.test(key))nextDir='RX';
      if(key==='properties'&&val&&typeof val==='object'){
        Object.keys(val).forEach(fname=>mark(fname,dir||'TX'));
      }
      walk(val,nextDir);
    });
  }
  if(spec&&!parseError){
    if(spec.paths&&typeof spec.paths==='object')paths.push(...Object.keys(spec.paths));
    walk(spec,null);
  }else{
    // Fallback: spec failed to parse (malformed file) — degrade gracefully with the old
    // indentation-based heuristic so the tool still returns *something* instead of nothing.
    const pr=/^\s{2,4}(\/[\w\/{}_\-.*]+):/gm;let m;
    while((m=pr.exec(raw))!==null)paths.push(m[1]);
    const pr2=/^[ \t]*(["']?)([\w][\w_\-]*)\1\s*:\s*\n[ \t]+(?:type|\$ref)\s*:/gm;
    while((m=pr2.exec(raw))!==null)mark(m[2],'TX');
  }
  return{fields:[...fields],paths:[...new Set(paths)],fieldDirs,spec,parseError};
}

async function runSw(){
  const xsdRaw=document.getElementById('xsd-ct').value.trim()||ST.xsd;
  const yamlRaw=document.getElementById('yaml-ct').value.trim()||ST.yaml;
  if(!xsdRaw&&!yamlRaw){toast('Upload or paste at least one file','warn');return;}
  const btn=document.getElementById('sw-btn');
  btn.disabled=true;
  btn.innerHTML=`<div class="ld" style="color:#0d0720"><div class="ldd"></div><div class="ldd"></div><div class="ldd"></div></div>`;
  const steps=['sw-s1','sw-s2','sw-s3','sw-s4'];
  steps.forEach((id,i)=>setTimeout(()=>{document.querySelectorAll('#psw .sb-it').forEach(e=>e.classList.remove('on'));document.getElementById(id)?.classList.add('on');},i*580));
  await new Promise(r=>setTimeout(r,2500));

  const xsdFields=parseXSD(xsdRaw);
  ST.xsdFields=xsdFields;
  ST.xsdFieldMap={};xsdFields.forEach(f=>ST.xsdFieldMap[f.name]=f);
  ST.swFieldEdits=ST.swFieldEdits||{};
  const yamlData=parseYAML(yamlRaw);
  const issues=crossValidate(xsdFields,yamlData,xsdRaw,yamlRaw);
  // Generate fully corrected YAML (also tells us which schema each direction's
  // missing fields were actually routed into — surfaced below for transparency)
  const correctedYaml=generateCorrectedYaml(xsdFields,yamlData,yamlRaw,xsdRaw);
  if(ST.lastRouting){
    const {tx,rx}=ST.lastRouting;
    if(tx)issues.push({t:'info',title:`Request-side missing fields routed into "${tx}"`,sub:'Preferred a PlainJSON / REQUEST schema over a Generic wrapper, where one was found.'});
    if(rx)issues.push({t:'info',title:`Response-side missing fields routed into "${rx}"`,sub:'Preferred a PlainJSON / RESPONSE schema over a Generic wrapper, where one was found.'});
  }
  renderReport(issues);
  document.getElementById('sw-out').innerHTML=`<button class="cbtn" onclick="navigator.clipboard.writeText(document.getElementById('sw-out').innerText.replace('Copy',''));toast('YAML copied')">Copy</button>${ehml(correctedYaml)}`;

  btn.disabled=false;
  btn.innerHTML='<i class="fa-solid fa-play"></i> Compare & Validate';
  const e=issues.filter(i=>i.t==='err').length;
  const w=issues.filter(i=>i.t==='warn').length;
  toast(`Done — ${e} errors, ${w} warnings`);
}

function crossValidate(xsdFields,yamlData,xsdRaw,yamlRaw){
  const issues=[];
  const hasXsd=xsdRaw&&xsdRaw.length>10;
  const hasYaml=yamlRaw&&yamlRaw.length>10;
  if(!hasXsd)issues.push({t:'warn',title:'XSD not provided',sub:'Upload XSD for complete field cross-validation'});
  if(!hasYaml)issues.push({t:'warn',title:'YAML not provided',sub:'Upload OpenAPI YAML for comparison'});
  if(hasXsd){
    const ns=xsdRaw.includes('xs:schema')||xsdRaw.includes('xsd:schema')||xsdRaw.includes('XMLSchema')||/<schema[\s>]/.test(xsdRaw);
    if(ns)issues.push({t:'ok',title:'XSD namespace valid',sub:`Found ${xsdFields.length} elements/attributes defined`});
    else issues.push({t:'warn',title:'Unusual XSD namespace',sub:'Expected xs: or xsd: prefix'});
  }
  if(hasYaml&&yamlData.parseError){
    issues.push({t:'err',title:'YAML/JSON could not be parsed',sub:`Parser error: ${yamlData.parseError} — fix the syntax and re-validate for an accurate comparison.`});
  }
  if(hasYaml){
    if(yamlRaw.includes('openapi: 3')||/"openapi"\s*:\s*"3/.test(yamlRaw))issues.push({t:'ok',title:'OpenAPI 3.x detected',sub:'Modern OpenAPI 3.0 format'});
    else if(yamlRaw.includes('swagger:')||/"swagger"\s*:/.test(yamlRaw))issues.push({t:'warn',title:'Swagger 2.0 detected',sub:'Consider upgrading to OpenAPI 3.0 (not changed automatically — your file is only patched for missing fields)'});
    else issues.push({t:'warn',title:'No openapi/swagger version field found',sub:'Not added automatically — only missing XSD fields are inserted, your file format is preserved as-is'});
    if(!yamlRaw.includes('info:')&&!/"info"\s*:/.test(yamlRaw))issues.push({t:'warn',title:'No info block found',sub:'Not added automatically — informational only'});
    else issues.push({t:'ok',title:'info block present',sub:'API metadata found'});
    if(!yamlRaw.includes('paths:')&&!/"paths"\s*:/.test(yamlRaw))issues.push({t:'warn',title:'No paths block found',sub:'Informational only — not modified'});
    else issues.push({t:'ok',title:'paths block found',sub:`${yamlData.paths.length} endpoint(s) detected`});
    if(!yamlRaw.includes('components:')&&!/"components"\s*:/.test(yamlRaw))issues.push({t:'warn',title:'No components/schemas section found',sub:'Missing fields could not be merged into a properties block — they will be appended at the end instead'});
    if(!yamlRaw.includes('securitySchemes')&&!/"securitySchemes"\s*:/.test(yamlRaw))issues.push({t:'warn',title:'No security schemes defined',sub:'Informational only — not added automatically'});
  }
  if(hasXsd&&hasYaml&&xsdFields.length>0){
    const ySet=new Set(yamlData.fields.map(f=>f.toLowerCase()));
    const missing=xsdFields.filter(f=>!ySet.has(f.name.toLowerCase()));
    const present=xsdFields.filter(f=>ySet.has(f.name.toLowerCase()));
    if(present.length){
      const mismatched=present.filter(f=>{
        const found=yamlData.fieldDirs[f.name.toLowerCase()];
        return found&&found!=='BOTH'&&f.direction&&found!==f.direction;
      });
      issues.push({t:'ok',title:`${present.length} XSD field(s) already in YAML`,sub:present.slice(0,6).map(f=>f.name).join(', ')+(present.length>6?` +${present.length-6} more`:'')});
      if(mismatched.length)issues.push({t:'warn',title:`${mismatched.length} field(s) found on the wrong side (TX/RX mismatch)`,sub:mismatched.map(f=>`${f.name} — XSD says ${f.direction}`).join(', ')});
    }
    if(missing.length){
      issues.push({t:'err',title:`${missing.length} XSD field(s) MISSING from YAML — click a field below to update it`,sub:'',missingFields:missing});
    } else{
      issues.push({t:'ok',title:'All XSD fields present in YAML',sub:'No missing fields detected'});
    }
    const xSet=new Set(xsdFields.map(f=>f.name.toLowerCase()));
    const extra=yamlData.fields.filter(f=>!xSet.has(f.toLowerCase()));
    if(extra.length)issues.push({t:'warn',title:`${extra.length} YAML field(s) not in XSD`,sub:extra.slice(0,5).join(', ')+(extra.length>5?` +${extra.length-5} more`:'')});
  }
  return issues;
}

function fieldToPropObj(f){
  const o={type:f.isArray?'array':f.oapiType};
  if(f.isArray)o.items={type:f.oapiType};
  if(f.format)o.format=f.format;
  if(f.length)o.maxLength=isNaN(+f.length)?f.length:+f.length;
  if(f.description)o.description=f.description;
  return o;
}
function yamlPropLines(f,indent){
  const lines=[`${indent}${f.name}:`,`${indent}  type: ${f.isArray?'array':f.oapiType}`];
  if(f.isArray)lines.push(`${indent}  items:`,`${indent}    type: ${f.oapiType}`);
  if(f.format)lines.push(`${indent}  format: ${f.format}`);
  if(f.length)lines.push(`${indent}  maxLength: ${f.length}`);
  if(f.description)lines.push(`${indent}  description: ${JSON.stringify(f.description)}`);
  return lines.join('\n');
}
function detectSpecFormat(raw){
  const t=raw.trim();
  return(t[0]==='{'||t[0]==='[')?'json':'yaml';
}
// Nearest requestBody/responses keyword before `pos`, to know if a "properties" block
// belongs to the request (TX) side or the response (RX) side.
function specDirectionAt(raw,pos){
  const head=raw.slice(0,pos);
  const reqIdx=Math.max(head.lastIndexOf('requestBody'),head.lastIndexOf('"requestBody"'));
  const respIdx=Math.max(head.lastIndexOf('responses'),head.lastIndexOf('"responses"'));
  if(respIdx>reqIdx)return'RX';
  if(reqIdx>-1)return'TX';
  return'TX';
}
// If a schema/key is plainly named "...Request"/"REQUEST" or "...Response"/"RESPONSE"
// (e.g. GenericRequest, PlainJSONRequest, REQUEST), that name is a much stronger
// signal than textual proximity to requestBody/responses — components/schemas
// definitions can sit anywhere in the file, far from where they're actually used,
// so the proximity heuristic alone misclassifies them. Returns null if the name
// gives no clear signal, so callers can fall back to specDirectionAt.
function directionFromName(name){
  if(!name)return null;
  if(/response/i.test(name))return'RX';
  if(/request/i.test(name))return'TX';
  return null;
}
// Walks upward from a "properties" line to find the nearest shallower key —
// i.e. the schema/object name this properties block actually belongs to
// (e.g. "PlainJSONRequest", "GenericRequest", "REQUEST", "RESPONSE"...).
// Used so missing fields can be routed into the right schema instead of
// just "the first properties block of the matching direction".
function findEnclosingName(raw,propMatchIndex,propIndentLen,fmt){
  const before=raw.slice(0,propMatchIndex);
  const lines=before.split(/\r?\n/);
  for(let i=lines.length-1;i>=0;i--){
    const line=lines[i];
    const m=fmt==='yaml'
      ? line.match(/^([ \t]*)([A-Za-z0-9_\-]+):\s*$/)
      : line.match(/^([ \t]*)"([A-Za-z0-9_\-]+)"\s*:\s*\{\s*$/);
    if(m&&m[1].length<propIndentLen)return m[2];
  }
  return null;
}
// Find every "properties" block in the RAW, un-reparsed text (works for both YAML and JSON),
// so we can splice new sibling keys in without re-serializing/reformatting the rest of the file.
function findPropertyBlocks(raw,fmt){
  const blocks=[];
  if(fmt==='yaml'){
    // Match the WHOLE line (including its \r\n or \n) so CRLF (Windows) files work too.
    const re=/^([ \t]*)properties:[ \t]*\r?\n/gm;
    let m;
    while((m=re.exec(raw))!==null){
      const insertAt=re.lastIndex; // right at the start of the next line
      const rest=raw.slice(insertAt);
      const childMatch=rest.match(/^([ \t]+)\S/);
      const childIndent=childMatch?childMatch[1]:m[1]+'  ';
      const name=findEnclosingName(raw,m.index,m[1].length,fmt);
      const dir=directionFromName(name)||specDirectionAt(raw,m.index);
      blocks.push({insertAt,indent:childIndent,dir,name});
    }
  }else{
    const re=/"properties"\s*:\s*\{/g;
    let m;
    while((m=re.exec(raw))!==null){
      const insertAt=m.index+m[0].length;
      const lineStart=raw.lastIndexOf('\n',m.index)+1;
      const lineIndent=(raw.slice(lineStart,m.index).match(/^[ \t]*/)||[''])[0];
      const afterWs=raw.slice(insertAt).match(/^\s*/)[0];
      const isEmpty=raw[insertAt+afterWs.length]==='}';
      const name=findEnclosingName(raw,lineStart,lineIndent.length,fmt);
      const dir=directionFromName(name)||specDirectionAt(raw,m.index);
      blocks.push({insertAt,indent:lineIndent+'  ',dir,isEmpty,name});
    }
  }
  return blocks;
}

// Picks which properties block a missing field should actually be routed
// into. GenericRequest/GenericResponse are typically thin wrappers that
// only carry a nested REQUEST/RESPONSE key (often a $ref) — the real
// business fields live in PlainJSONRequest/PlainJSONResponse, or directly
// under a "REQUEST"/"RESPONSE" object. Preference order:
//   1. a schema whose name matches "PlainJSON<Request|Response>"
//   2. a block literally named "REQUEST" / "RESPONSE"
//   3. any block whose name does NOT look like "Generic<Request|Response>"
//   4. the first block found for that direction (last-resort fallback)
function pickTargetBlock(list,kind){
  if(!list.length)return null;
  const plainRe=kind==='RX'?/plain.?json.?response/i:/plain.?json.?request/i;
  const bareRe=kind==='RX'?/^response$/i:/^request$/i;
  const genRe=kind==='RX'?/generic.?response/i:/generic.?request/i;
  return list.find(b=>b.name&&plainRe.test(b.name))
      || list.find(b=>b.name&&bareRe.test(b.name))
      || list.find(b=>!(b.name&&genRe.test(b.name)))
      || list[0];
}

// Patches ONLY the missing XSD fields into the user's own YAML/JSON, exactly as they
// uploaded it — same format, same indentation, same everything else. Nothing is
// regenerated from scratch and nothing else is rewritten or hardcoded.
function generateCorrectedYaml(xsdFields,yamlData,existingYaml,xsdRaw){
  const addMissing=document.getElementById('sw-addmissing')?.checked!==false;
  ST.lastRouting=null;

  function effField(f){
    const e=ST.swFieldEdits&&ST.swFieldEdits[f.name];
    return e?{...f,...e}:f;
  }

  if(!existingYaml||!existingYaml.trim()){
    return '# No swagger (YAML/JSON) file was provided.\n# Upload or paste your existing file — only the missing XSD fields will be\n# inserted into it, in its own original format. Nothing is generated from scratch.';
  }
  if(!xsdFields.length||!addMissing){
    return existingYaml; // nothing to compare against / auto-update disabled — return untouched
  }

  const ySet=new Set(yamlData.fields.map(f=>f.toLowerCase()));
  const missing=xsdFields.filter(f=>!ySet.has(f.name.toLowerCase()));
  if(!missing.length)return existingYaml; // already in sync — return exactly as given, unchanged

  const fmt=detectSpecFormat(existingYaml);
  const blocks=findPropertyBlocks(existingYaml,fmt);

  if(!blocks.length){
    // No properties: / "properties": block exists anywhere to merge into —
    // append a clearly-marked section rather than guessing at structure.
    const note=fmt==='json'
      ?'\n\n/* === MISSING FIELDS FROM XSD — no "properties" object found to merge into === */\n'+
        JSON.stringify(Object.fromEntries(missing.map(f0=>{const f=effField(f0);return[f.name,fieldToPropObj(f)];})),null,2)
      :'\n\n# === MISSING FIELDS FROM XSD — no "properties:" block found to merge into ===\n'+
        missing.map(f0=>yamlPropLines(effField(f0),'  ')).join('\n');
    return existingYaml+note;
  }

  // Route each missing field to the properties block matching its XSD direction (TX/RX).
  // Preference order (see pickTargetBlock): PlainJSONRequest/PlainJSONResponse,
  // then a bare REQUEST/RESPONSE block, then anything that isn't the Generic
  // wrapper, then finally whatever block was found first as a last resort.
  const txBlocks=blocks.filter(b=>b.dir==='TX');
  const rxBlocks=blocks.filter(b=>b.dir==='RX');
  const txTarget=pickTargetBlock(txBlocks,'TX');
  const rxTarget=pickTargetBlock(rxBlocks,'RX');
  ST.lastRouting={tx:txTarget&&txTarget.name,rx:rxTarget&&rxTarget.name};
  const byInsertAt=new Map();
  missing.forEach(f0=>{
    const f=effField(f0);
    const target=(f.direction==='RX'?rxTarget:txTarget)||blocks[0];
    if(!byInsertAt.has(target.insertAt))byInsertAt.set(target.insertAt,{blk:target,fields:[]});
    byInsertAt.get(target.insertAt).fields.push(f);
  });

  // Apply insertions back-to-front so earlier offsets stay valid after each splice.
  let out=existingYaml;
  const inserts=[...byInsertAt.values()].sort((a,b)=>b.blk.insertAt-a.blk.insertAt);
  inserts.forEach(({blk,fields})=>{
    let chunk;
    if(fmt==='json'){
      const body=fields.map(f=>{
        const objStr=JSON.stringify(fieldToPropObj(f),null,2).split('\n').join('\n'+blk.indent);
        return `${blk.indent}"${f.name}": ${objStr}`;
      }).join(',\n');
      chunk='\n'+body+(blk.isEmpty?'':',');
    }else{
      chunk=fields.map(f=>yamlPropLines(f,blk.indent)).join('\n')+'\n';
    }
    out=out.slice(0,blk.insertAt)+chunk+out.slice(blk.insertAt);
  });
  return out;
}
