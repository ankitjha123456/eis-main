function dbReset(){
  ['FETCH_FLAG','CACHE','FIELD_NAME','EIS_DMZ_URL','SYS_SERVICE','SYS_URL','HTTPTimeOut','CONTENT_CHECK','SOURCE_CONFIG','THIRD_PARTY_URL','SERVICE_NAME_LOCAL','INTEGRATION_NODE_NAME_LOCAL','INTEGRATION_SERVER_NAME_LOCAL'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  document.getElementById('db-out').innerHTML=`<div style="color:var(--t3);text-align:center;padding:28px;font-size:12px"><i class="fa-solid fa-code" style="font-size:26px;display:block;margin-bottom:8px;opacity:.28"></i>Fill in the fields above and click <strong style="color:var(--teal)">Generate Query</strong></div>`;
