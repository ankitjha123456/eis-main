CREATE COMPUTE MODULE postUpdate_Compute1
    CREATE FUNCTION Main() RETURNS BOOLEAN
    BEGIN
        CREATE LASTCHILD OF OutputRoot DOMAIN('JSON');

        SET OutputRoot.JSON.Data.FileName = InputLocalEnvironment.File.Read.Name;

        -- Cast BLOB to string
        DECLARE rawContent CHARACTER;
        SET rawContent = CAST(InputRoot.BLOB.BLOB AS CHARACTER
                            CCSID COALESCE(InputRoot.Properties.CodedCharSetId, 5348)
                            ENCODING COALESCE(InputRoot.Properties.Encoding, 546));

        -- Remove newlines and tabs
        SET rawContent = REPLACE(rawContent, '\n', '');
        SET rawContent = REPLACE(rawContent, '\t', '');
        SET rawContent = REPLACE(rawContent, '\r', '');

        SET OutputRoot.JSON.Data.FileContent = rawContent;

        RETURN TRUE;
    END;
END MODULE;