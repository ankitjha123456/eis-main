import com.ibm.broker.javacompute.MbJavaComputeNode;
import com.ibm.broker.plugin.*;

import java.io.File;
import java.io.FilenameFilter;
import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.GregorianCalendar;

public class ListFilesJCN extends MbJavaComputeNode {

    @Override
    public void evaluate(MbMessageAssembly inAssembly) throws MbException {

        MbOutputTerminal out = getOutputTerminal("out");

        MbMessage inMessage = inAssembly.getMessage();
        MbMessage outMessage = new MbMessage(inMessage);
        MbMessageAssembly outAssembly = new MbMessageAssembly(inAssembly, outMessage);

        try {
            // Get Environment variables
            MbElement envRoot = inAssembly.getGlobalEnvironment().getRootElement();
            MbElement variables = envRoot.getFirstElementByPath("Variables");

            String filePath = variables.getFirstElementByPath("FilePath").getValueAsString();
            String pattern = variables.getFirstElementByPath("Pattern").getValueAsString();

            String regex = pattern.replace("*", ".*");

            File dir = new File(filePath);

            if (!dir.exists() || !dir.isDirectory()) {
                throw new MbUserException(this, "evaluate()", "", "",
                        "Invalid directory path: " + filePath, null);
            }

            File[] files = dir.listFiles((d, name) -> name.matches(regex));

            // LocalEnvironment
            MbElement localEnvRoot = outAssembly.getLocalEnvironment().getRootElement();

            // Files root
            MbElement filesRoot = localEnvRoot.createElementAsLastChild(MbElement.TYPE_NAME, "Files", null);

            // ===== Header Fields =====
            String timeStamp = new SimpleDateFormat("yyyyMMdd_HHmmss_SSSSSS").format(new Date());

            filesRoot.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "TimeStamp", timeStamp);
            filesRoot.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "ProcessedBy", "File Exists");
            filesRoot.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "FromFTP", false);

            int totalFiles = (files != null) ? files.length : 0;
            filesRoot.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "TotalInList", totalFiles);

            // ===== File List =====
            if (files != null) {
                for (File f : files) {

                    MbElement fileElement = filesRoot.createElementAsLastChild(MbElement.TYPE_NAME, "File", null);

                    fileElement.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "Directory", f.getParent());
                    fileElement.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "Name", f.getName());

                    // TIMESTAMP as GregorianCalendar
                    GregorianCalendar cal = new GregorianCalendar();
                    cal.setTimeInMillis(f.lastModified());

                    fileElement.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "LastModified", cal);

                    fileElement.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "IsEmpty", f.length() == 0);

                    // Wildcard structure
                    MbElement wildcard = fileElement.createElementAsLastChild(MbElement.TYPE_NAME, "Wildcard", null);

                    String baseName = f.getName();
                    if (baseName.contains(".")) {
                        baseName = baseName.substring(0, baseName.lastIndexOf("."));
                    }

                    wildcard.createElementAsLastChild(MbElement.TYPE_NAME_VALUE, "WildcardMatch", baseName);
                }
            }

        } catch (Exception e) {
            throw new MbUserException(this, "evaluate()", "", "", e.toString(), null);
        }

        out.propagate(outAssembly);
    }
}