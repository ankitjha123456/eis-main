async function dbSubmit(){
  const btn=document.getElementById('db-btn');
  const apiUrl=document.getElementById('ace-url').value.trim();
  // Only real query-mapping fields go to the API. Service Name / Integration
  // Node Name / Integration Server Name are LOCAL DISPLAY LABELS ONLY — they
  // are never part of the query mapping and are never sent in this payload.
  const data={FETCH_FLAG:$v('FETCH_FLAG'),CACHE:$v('CACHE'),FIELD_NAME:$v('FIELD_NAME'),EIS_DMZ_URL:$v('EIS_DMZ_URL'),SYS_SERVICE:$v('SYS_SERVICE'),SYS_URL:$v('SYS_URL'),HTTPTimeOut:$v('HTTPTimeOut'),CONTENT_CHECK:$v('CONTENT_CHECK'),SOURCE_CONFIG:$v('SOURCE_CONFIG'),THIRD_PARTY_URL:$v('THIRD_PARTY_URL')};
  const localLabels={serviceName:$v('SERVICE_NAME_LOCAL'),nodeName:$v('INTEGRATION_NODE_NAME_LOCAL'),serverName:$v('INTEGRATION_SERVER_NAME_LOCAL')};
  btn.disabled=true;
  btn.innerHTML=`<div class="ld" style="color:#041410"><div class="ldd"></div><div class="ldd"></div><div class="ldd"></div></div>`;
  document.getElementById('db-out').innerHTML=`<div style="color:var(--t2);text-align:center;padding:24px;font-size:12px"><div class="ld" style="color:var(--teal);margin:0 auto 8px"><div class="ldd"></div><div class="ldd"></div><div class="ldd"></div></div>Calling ACE server…</div>`;
  const pgh=apiProgressStart('db',['Connecting to ACE server…','Sending request…','Waiting for response…','Receiving data…']);
  const t0=performance.now();
  try{
    const resp=await fetch(apiUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    const result=await resp.json();
    const ms=Math.round(performance.now()-t0);
    document.getElementById('db-meta').textContent=`${resp.status} · ${ms}ms`;
    renderAce(result,data,localLabels);
    apiProgressFinish(pgh,true);
    toast(`Queries generated in ${ms}ms`);
  }catch(err){
    const ms=Math.round(performance.now()-t0);
    document.getElementById('db-meta').textContent=`Error · ${ms}ms`;
    document.getElementById('db-out').innerHTML=`<div style="padding:14px"><div style="color:var(--red);font-size:12.5px;margin-bottom:8px"><i class="fa-solid fa-triangle-exclamation"></i> ${err.message}</div><div style="color:var(--t2);font-size:11.5px">Check ACE server at:<br><code style="color:var(--teal);font-family:var(--fm)">${apiUrl}</code></div></div>`;
    apiProgressFinish(pgh,false);
    toast('ACE server error','err');
  }finally{btn.disabled=false;btn.innerHTML='<i class="fa-solid fa-play"></i> Generate Query';}
}
const SQL_KEYS=['EIS_DMZ_URL','EISSOURCEID','SYSSERVICES','EIS_SYS_URL','HTTPTIMEOUT','CONTENTCHCK','THRDPRTYURL','APIPARAMETR','ACCESMASTER','API_MASTERS'];
function renderAce(result,reqData,localLabels){
  const c=document.getElementById('db-out');c.innerHTML='';
  c.appendChild(buildCacheBlock(result,reqData,localLabels));
  if(result.RESPONSE_DATE){
    const m=document.createElement('p');m.className='sql-meta';
    m.innerHTML=`<i class="fa-solid fa-clock" style="margin-right:4px;color:var(--teal)"></i>${result.RESPONSE_DATE}`;
    c.appendChild(m);
  }
}

// Builds the single-tab, Postman-style response view. Output format:
//   Service Name: <value>
//   Integration Node Name: <value>
//   Integration Server Name: <value>
//   Cache:{ -Query: <actual query value>, -Query: <actual query value>, ... }
// The Service/Node/Server lines are LOCAL DISPLAY LABELS ONLY — they never
// went to the API and never came back from it; they are stitched in here
// purely for readability of the output, as plain "key: value" lines with
// no extra tag/box around them. Only the actual query results are wrapped
// in the Cache:{ } tag, exactly like before.
function buildCacheBlock(result,reqData,localLabels){
  localLabels=localLabels||{};
  const entries=[];
  SQL_KEYS.forEach(k=>{
    if(result[k]!==undefined&&result[k]!==null&&result[k]!=='')entries.push([k,result[k]]);
  });

  const metaRows=[
    ['Service Name',localLabels.serviceName],
    ['Integration Node Name',localLabels.nodeName],
    ['Integration Server Name',localLabels.serverName]
  ].filter(([,v])=>v);

  const wrap=document.createElement('div');
  wrap.className='flat-out';
  wrap.style.marginTop='0';

  const metaLineHtml=metaRows.map(([k,v])=>
    `<div class="fo-row"><span class="fo-key">${esc(k)}:</span> <span class="fo-val">${esc(v)}</span></div>`
  ).join('');
  const metaLineText=metaRows.map(([k,v])=>`${k}: ${v}`).join('\n');

  if(!entries.length){
    wrap.innerHTML=`<div class="fo-body">${metaLineHtml}<div class="fo-cache-pre" style="color:var(--t3)">Cache:{\n  no query results returned — check parameters\n}</div></div>`;
    return wrap;
  }

  const que='Query';
  const cacheText='Cache:{\n'+entries.map(([k,v])=>`  -${que}: ${v}`).join(',\n')+'\n}';
  const allText=(metaLineText?metaLineText+'\n':'')+cacheText;
  const entryLineHtml=entries.map(([k,v])=>
    `  <span class="fo-key">-${que}:</span> <span class="fo-val fo-copyable" data-copy="${esc(v)}" data-label="${esc(k)}" title="Click to copy this value">${esc(v)}</span>`
  ).join(',\n');
  wrap.innerHTML=`<button class="cbtn" id="cb-copyall">Copy</button><div class="fo-body">${metaLineHtml}<div class="fo-cache-pre">Cache:{\n${entryLineHtml}\n}</div></div>`;
  wrap.querySelector('#cb-copyall').onclick=()=>{navigator.clipboard.writeText(allText);toast('Copied full output');};
  wrap.querySelectorAll('.fo-copyable').forEach(el=>{
    el.onclick=()=>{navigator.clipboard.writeText(el.dataset.copy);toast('Copied: '+el.dataset.label);};
  });
  return wrap;
}
function esc(s){return String(s).replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>');}

// Postman-style Cache summary for the Request Hit / API Client response (single Body tab)
function buildReqCacheBlock(resp,json){
  const entries=[];
  ['cache-control','etag','age','expires','x-cache','x-cache-hits'].forEach(h=>{
    const v=resp.headers.get(h);
    if(v)entries.push([h,v]);
  });
  // walk JSON body (shallow, one level of nesting) for any key containing "cache"
  function scan(obj,prefix){
    if(!obj||typeof obj!=='object')return;
    Object.entries(obj).forEach(([k,v])=>{
      if(/cache/i.test(k)) entries.push([prefix+k, typeof v==='object'?JSON.stringify(v):String(v)]);
      else if(v&&typeof v==='object'&&!Array.isArray(v)) scan(v,prefix+k+'.');
    });
  }
  if(json)scan(json,'');
  const wrap=document.createElement('div');
  wrap.className='cache-block';
  wrap.id='req-cache-block';
  const body=entries.length
    ? entries.map(([k,v])=>`  <span class="cb-key">-${esc(k)}</span>: <span class="cb-val">${esc(v)}</span>`).join(',\n')
    : '  <span class="cb-val">no cache headers or fields found in this response</span>';
  wrap.innerHTML=`<div class="cb-h"><i class="fa-solid fa-layer-group"></i>Cache</div><div class="cb-body">Cache:{\n${body}\n}</div>`;
  return wrap;
}
function $v(id){const e=document.getElementById(id);return e?e.value:'';}

// ══════════ GENERIC API CALL PROGRESS BAR ══════════
function apiProgressStart(prefix,stages){
  const wrap=document.getElementById(prefix+'-pgwrap');
  const fill=document.getElementById(prefix+'-pgfill');
  const pct=document.getElementById(prefix+'-pgpct');
  const lbl=document.getElementById(prefix+'-pglabel-txt');
  if(!wrap)return null;
  wrap.classList.add('on');
  fill.style.background='';
  let p=0;
  lbl.textContent=stages[0];
  pct.textContent='0%';
  fill.style.width='0%';
  const iv=setInterval(()=>{
    p=Math.min(p+Math.random()*9+3,92);
    fill.style.width=p.toFixed(0)+'%';
    pct.textContent=Math.round(p)+'%';
    const si=Math.min(Math.floor(p/(100/stages.length)),stages.length-1);
    lbl.textContent=stages[si];
  },220);
  return{iv,fill,pct,wrap,lbl};
}
function apiProgressFinish(h,ok){
  if(!h)return;
  clearInterval(h.iv);
  h.fill.style.width='100%';h.pct.textContent='100%';
