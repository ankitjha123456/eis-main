server {
    listen 4415;
    server_name 10.177.44.29;

    root /usr/share/nginx/html;

    # index.html at /
    location / {
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # EISdev/index.html at /EISdev
    location /EISdev {
        alias /usr/share/nginx/html/EISdev;
        index index.html;
        try_files $uri $uri/ /EISdev/index.html;
    }

    # API proxy moved to its own dedicated path
    location /EISdev-api/ {
        proxy_pass http://10.177.44.22:4002/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}