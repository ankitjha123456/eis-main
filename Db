<div class="result">
    <h2>
        <i class="fa-solid fa-file-code"></i>
        Generated SQL
    </h2>

    <div id="queryOutput"></div>
</div>




document.getElementById("queryForm").addEventListener("submit", function(e) {
    e.preventDefault();

    const data = {
        "FETCH_FLAG": document.getElementById("FETCH_FLAG").value,
        "CACHE": document.getElementById("CACHE").value,
        "FIELD_NAME": document.getElementById("FIELD_NAME").value,
        "EIS_DMZ_URL": document.getElementById("EIS_DMZ_URL").value,
        "SYS_SERVICE": document.getElementById("SYS_SERVICE").value,
        "SYS_URL": document.getElementById("SYS_URL").value,
        "HTTPTimeOut": document.getElementById("HTTPTimeOut").value,
        "CONTENT_CHECK": document.getElementById("CONTENT_CHECK").value,
        "SOURCE_CONFIG": document.getElementById("SOURCE_CONFIG").value,
        "THIRD_PARTY_URL": document.getElementById("THIRD_PARTY_URL").value,
        "REQUEST_REFERENCE_NUMBER": document.getElementById("REQUEST_REFERENCE_NUMBER").value
    };

    fetch("http://10.177.44.29:4415/EISdev/depositAccShort/details/accounts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(result => {
        renderQueries(result);
    })
    .catch(err => {
        document.getElementById("queryOutput").innerHTML =
            `<p style="color:red;">Error: ${err.message}</p>`;
    });
});

function renderQueries(result) {
    const sqlKeys = [
        "EIS_DMZ_URL", "EISSOURCEID", "SYSSERVICES", "EIS_SYS_URL",
        "HTTPTIMEOUT", "CONTENTCHCK", "THRDPRTYURL",
        "APIPARAMETR", "ACCESMASTER", "API_MASTERS"
    ];

    const container = document.getElementById("queryOutput");
    container.innerHTML = "";

    sqlKeys.forEach(key => {
        if (!result[key]) return;

        const block = document.createElement("div");
        block.className = "sql-block";

        block.innerHTML = `
            <div class="sql-label">
                <span>${key}</span>
                <button type="button" class="copy-btn">
                    <i class="fa-solid fa-copy"></i> Copy
                </button>
            </div>
            <textarea rows="4" readonly>${result[key]}</textarea>
        `;

        block.querySelector(".copy-btn").addEventListener("click", () => {
            navigator.clipboard.writeText(result[key]);
        });

        container.appendChild(block);
    });

    if (result.REQUEST_REFERENCE_NUMBER || result.RESPONSE_DATE) {
        const meta = document.createElement("p");
        meta.className = "sql-meta";
        meta.textContent =
            `Ref: ${result.REQUEST_REFERENCE_NUMBER || "-"} | ${result.RESPONSE_DATE || ""}`;
        container.appendChild(meta);
    }
}







.sql-block {
    margin-bottom: 16px;
    border: 1px solid #ddd;
    border-radius: 6px;
    overflow: hidden;
}

.sql-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f3f3f3;
    padding: 6px 10px;
    font-weight: 600;
    font-size: 0.9rem;
}

.copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
}

.sql-block textarea {
    width: 100%;
    border: none;
    padding: 8px 10px;
    font-family: monospace;
    font-size: 0.85rem;
    resize: vertical;
}

.sql-meta {
    font-size: 0.8rem;
    color: #666;
    margin-top: 8px;
}
