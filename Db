- task: CmdLine@2
  displayName: Update cache in Database
  env:
    BRANCH: $(Build.SourceBranchName)
  inputs:
    workingDirectory: $(Pipeline.Workspace)/drop/
    script: |
      source ~/.bashrc
      set -e

      if [ ! -f config.yml ]; then
        echo "config.yml file was not found !!"
        exit 1
      fi

      mapfile -t QUERIES < <(yq ".Cache[].Query" config.yml)

      if [ ${#QUERIES[@]} -eq 0 ]; then
        echo "No queries found in config.yml"
        exit 1
      fi

      echo "Found ${#QUERIES[@]} queries. Executing as a single transaction..."

      # Build all queries into one batch ending with COMMIT WORK
      TRANSACTION_SQL=""
      for SQL in "${QUERIES[@]}"; do
        TRANSACTION_SQL="${TRANSACTION_SQL}${SQL};"$'\n'
      done
      TRANSACTION_SQL="${TRANSACTION_SQL}COMMIT WORK;"

      # Write SQL to temp file to avoid heredoc indentation issues
      TMPFILE=$(mktemp /tmp/cache_sql_XXXXXX.sql)
      echo "${TRANSACTION_SQL}" > "$TMPFILE"

      # Execute all queries in single isql session
      TRANSACTION_OUTPUT=$(isql -v "$BRANCH" "$DB_USER" "$DB_PASS" -b < "$TMPFILE" 2>&1)
      ISQL_STATUS=$?
      rm -f "$TMPFILE"

      echo "$TRANSACTION_OUTPUT"

      # Check for any Oracle or driver errors
      if [ $ISQL_STATUS -ne 0 ] || echo "$TRANSACTION_OUTPUT" | grep -qiE "ORA-[0-9]+|\[ISQL\]ERROR|Could not SQLExecute"; then
        echo ""
        echo "ERROR DETECTED — Sending ROLLBACK WORK..."

        # Send ROLLBACK WORK via temp file
        RBFILE=$(mktemp /tmp/cache_rb_XXXXXX.sql)
        echo "ROLLBACK WORK;" > "$RBFILE"
        ROLLBACK_OUTPUT=$(isql -v "$BRANCH" "$DB_USER" "$DB_PASS" -b < "$RBFILE" 2>&1)
        rm -f "$RBFILE"
        echo "$ROLLBACK_OUTPUT"

        # Identify which query failed
        SUCCESS_COUNT=$(echo "$TRANSACTION_OUTPUT" | grep -ci "SQLRowCount")
        echo ""
        echo "Queries confirmed before failure: $SUCCESS_COUNT / ${#QUERIES[@]}"

        if [ "$SUCCESS_COUNT" -lt "${#QUERIES[@]}" ]; then
          FAILED_INDEX=$SUCCESS_COUNT
          echo "Failed query [index $FAILED_INDEX]: ${QUERIES[$FAILED_INDEX]}"
        fi

        ORA_ERR=$(echo "$TRANSACTION_OUTPUT" | grep -oiE "ORA-[0-9]+[^]]*" | head -1)
        [ -n "$ORA_ERR" ] && echo "Oracle error: $ORA_ERR"

        echo ""
        echo "All changes ROLLED BACK."
        exit 1
      fi

      # Verify every query produced SQLRowCount confirmation
      SUCCESS_COUNT=$(echo "$TRANSACTION_OUTPUT" | grep -ci "SQLRowCount")
      if [ "$SUCCESS_COUNT" -ne "${#QUERIES[@]}" ]; then
        echo ""
        echo "WARNING: Expected ${#QUERIES[@]} confirmations, got $SUCCESS_COUNT"
        echo "Sending ROLLBACK WORK..."

        RBFILE=$(mktemp /tmp/cache_rb_XXXXXX.sql)
        echo "ROLLBACK WORK;" > "$RBFILE"
        isql -v "$BRANCH" "$DB_USER" "$DB_PASS" -b < "$RBFILE" 2>&1
        rm -f "$RBFILE"

        echo "All changes ROLLED BACK."
        exit 1
      fi

      echo ""
      echo "All ${#QUERIES[@]} queries executed and COMMITTED successfully."