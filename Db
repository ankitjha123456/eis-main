const BACKEND_URL = "http://10.177.44.29:4415/EISdev/depositAccShort/details/accounts";

const SQL_KEYS = [
    "EIS_DMZ_URL",
    "EISSOURCEID",
    "SYSSERVICES",
    "EIS_SYS_URL",
    "HTTPTIMEOUT",
    "CONTENTCHCK",
    "THRDPRTYURL",
    "APIPARAMETR",
    "ACCESMASTER",
    "API_MASTERS"
];

let lastResult = null;

document.getElementById("queryForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const data = {
        "FETCH_FLAG": document.getElementById("FETCH_FLAG").value,
        "CACHE": document.getElementById("CACHE").value,
        "FIELD_NAME": document.getElementById("FIELD_NAME").value,
        "EIS_DMZ_URL": document.getElementById("EIS_DMZ_URL").value,
        "SYS_SERVICE": document.getElementById("SYS_SERVICE").value,
        "SYS_URL": document.getElementById("SYS_URL").value,
        "HTTPTimeOut": document.getElementById("HTTPTimeOut").value,
        "CONTENT_CHECK": document.getElementById("CONTENT_CHECK").value,
        "SOURCE_CONFIG": document.getElementById("SOURCE_CONFIG").value,
        "THIRD_PARTY_URL": document.getElementById("THIRD_PARTY_URL").value,
        "REQUEST_REFERENCE_NUMBER": document.getElementById("REQUEST_REFERENCE_NUMBER").value
    };

    const output = document.getElementById("queryOutput");
    output.innerHTML = `<p class="placeholder">Generating...</p>`;

    fetch(BACKEND_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    })
        .then(res => {
            if (!res.ok) {
                throw new Error(`Server responded with ${res.status}`);
            }
            return res.json();
        })
        .then(result => {
            lastResult = result;
            renderQueries(result);
        })
        .catch(err => {
            output.innerHTML = `<p class="error">Error: ${err.message}</p>`;
            document.getElementById("copyAllBtn").style.display = "none";
        });
});

document.getElementById("queryForm").addEventListener("reset", function () {
    lastResult = null;
    document.getElementById("queryOutput").innerHTML =
        `<p class="placeholder">No queries generated yet. Fill the form and click "Generate Query".</p>`;
    document.getElementById("copyAllBtn").style.display = "none";
});

function renderQueries(result) {
    const container = document.getElementById("queryOutput");
    const copyAllBtn = document.getElementById("copyAllBtn");
    container.innerHTML = "";

    const foundKeys = SQL_KEYS.filter(key => result[key]);

    if (foundKeys.length === 0) {
        container.innerHTML = `<p class="error">No SQL statements found in the response.</p>`;
        copyAllBtn.style.display = "none";
        return;
    }

    foundKeys.forEach(key => {
        const block = document.createElement("div");
        block.className = "sql-block";

        block.innerHTML = `
            <div class="sql-label">
                <span>${key}</span>
                <button type="button" class="copy-btn">
                    <i class="fa-solid fa-copy"></i> Copy
                </button>
            </div>
            <textarea rows="4" readonly>${result[key]}</textarea>
        `;

        const copyBtn = block.querySelector(".copy-btn");
        const textarea = block.querySelector("textarea");

        copyBtn.addEventListener("click", () => {
            copyToClipboard(textarea.value, copyBtn);
        });

        container.appendChild(block);
    });

    if (result.REQUEST_REFERENCE_NUMBER || result.RESPONSE_DATE) {
        const meta = document.createElement("p");
        meta.className = "sql-meta";
        meta.textContent = `Ref: ${result.REQUEST_REFERENCE_NUMBER || "-"} | ${result.RESPONSE_DATE || ""}`;
        container.appendChild(meta);
    }

    copyAllBtn.style.display = "inline-flex";
}

document.getElementById("copyAllBtn").addEventListener("click", () => {
    if (!lastResult) return;

    const combined = SQL_KEYS
        .filter(key => lastResult[key])
        .map(key => `-- ${key}\n${lastResult[key]}`)
        .join("\n\n");

    copyToClipboard(combined, document.getElementById("copyAllBtn"));
});

// Works over plain HTTP too (navigator.clipboard requires HTTPS/localhost)
function copyToClipboard(text, btnEl) {
    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.style.position = "fixed";
    textarea.style.opacity = "0";
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();

    let success = false;
    try {
        success = document.execCommand("copy");
    } catch (err) {
        console.error("Copy failed", err);
    }

    document.body.removeChild(textarea);

    if (btnEl) {
        const original = btnEl.innerHTML;
        btnEl.innerHTML = success
            ? `<i class="fa-solid fa-check"></i> Copied`
            : `<i class="fa-solid fa-xmark"></i> Failed`;
        setTimeout(() => {
            btnEl.innerHTML = original;
        }, 1500);
    }
}