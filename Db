    <body>
        <div class="container">
            <div class="header">
                <i class="fa-solid fa-database"></i>
                <h1>IBM ACE SQL Query Generator</h1>
                <p>Generate Dynamic Configuration Queries</p>
            </div>

            <form id="queryForm">
                <div class="grid">
                    <div class="form-group">
                        <label><i class="fa-solid fa-filter"></i> Fetch Flag</label>
                        <input type="text" id="FETCH_FLAG" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-layer-group"></i> Cache For</label>
                        <input type="text" id="CACHE" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-table-columns"></i> Field Name</label>
                        <input type="text" id="FIELD_NAME" />
                    </div>

