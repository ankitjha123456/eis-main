# ======================== BUILD STAGE ========================
# MODIFICATION SUMMARY (only these two fields changed):
#   dependsOn : added Hash_Validation
#   condition : updated to allow Build when Hash_Validation is
#               Succeeded (hash matched or approval granted) OR
#               Skipped (non-PR run, stage condition was false).
#   All other Build stage logic is UNCHANGED.
# =============================================================
- stage: Build
  displayName: Build Stage
  dependsOn:
    - Validation_Stage
    # - Hash_Validation
  pool:
    name: TFS-RH-1
  condition: succeeded('Validation_Stage')

  jobs:
    - job: Build_Job
      displayName: Agent Build job
      workspace:
        clean: all

      steps:

        - checkout: self
          path: s/app

        - checkout: git://devops_testing/eis-configuration@refs/heads/config
          path: s/eis-configurations

        - task: CmdLine@2
          displayName: Building Bar file
          env:
            BRANCH: $(Build.SourceBranchName)
          inputs:
            script: |
              set -e
              . /opt/IBM/ace/server/bin/mqsiprofile

              applicationName=$(ls -1 "$(Build.SourcesDirectory)/app" | grep -vE "Config|README.md|azure-pipelines.yml" | tail -n 1)

              mkdir -p "$(Build.SourcesDirectory)/app/Config"

              yq e ".$applicationName | select(. !=null)" \
                "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_config.yml" \
                > "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"

              if [ -s "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml" ]; then
                config_path="$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"
                yq -i ".ApplicationName = \"$applicationName\"" "$config_path"
                cp "$config_path" "$(Build.BinariesDirectory)/config.yml"
              else
                yq e ".$BRANCH" "$(Build.SourcesDirectory)/app/Config/config.yml" \
                  > "$(Build.SourcesDirectory)/app/Config/temp.yml" &&
                mv "$(Build.SourcesDirectory)/app/Config/temp.yml" "$(Build.SourcesDirectory)/app/Config/config.yml"
                config_path="$(Build.SourcesDirectory)/app/Config/config.yml"
                yq -i ".ApplicationName = \"$applicationName\"" "$config_path"
                cp "$config_path" "$(Build.BinariesDirectory)/config.yml"
              fi

              override_path=""
              if [ -f "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_override.yml" ]; then
                yq ".$applicationName | to_entries[] | .key + \" = \" + .value" \
                  "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_override.yml" \
                  > "$(Build.SourcesDirectory)/app/Config/override.properties"
                override_path="$(Build.SourcesDirectory)/app/Config/override.properties"
              fi

              if [ -s "$override_path" ]; then
                ibmint package \
                  --input-path "$(Build.SourcesDirectory)/app" \
                  --output-bar-file "$(Build.BinariesDirectory)/$applicationName.bar" \
                  --java-version 8 \
                  --overrides-file "$override_path"
              else
                ibmint package \
                  --input-path "$(Build.SourcesDirectory)/app" \
                  --output-bar-file "$(Build.BinariesDirectory)/$applicationName.bar" \
                  --java-version 8
              fi

              mqsireadbar -b "$(Build.BinariesDirectory)/$applicationName.bar" -r \
                | grep "=" | sed -e 's/^[[:space:]]*//' \
                > "$(Build.BinariesDirectory)/override.properties"


        - task: CopyFiles@2
          inputs:
            SourceFolder: $(Build.BinariesDirectory)
            TargetFolder: $(Build.ArtifactStagingDirectory)
            OverWrite: true

        - task: PublishBuildArtifacts@1
          inputs:
            PathtoPublish: $(Build.ArtifactStagingDirectory)
            ArtifactName: drop

        - task: CmdLine@2
          displayName: Display override.properties
          condition: always()
          inputs:
            script: |
              OVERRIDE_FILE="$(Build.BinariesDirectory)/override.properties"
              if [ -f "$OVERRIDE_FILE" ]; then
                echo "=========override.properties contents ========="
                cat "$OVERRIDE_FILE"
                echo "==============================================="
              else
                echo "ERROR : override.properties not found at $OVERRIDE_FILE" 
              fi

# ================= RELEASE STAGE =================
- stage: Release
  displayName: Deploy Stage
  pool:
    name: TFS-RH-1
  dependsOn:
    - Validation_Stage
    - Build
  condition: |
    and(
      succeeded('Build'),
      eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.DeployFlag'], 'true'),
      ne(variables['Build.SourceBranchName'], 'main')
    )
  jobs:
    
    - deployment: DeployApp
      displayName: Deployment Job
      environment: $(Build.SourceBranchName)
      workspace:
        clean: all

      strategy:
        runOnce:
          deploy:
            steps:

              - download: current
                artifact: drop

              - task: CmdLine@2
                displayName: Deploying Bar File
                env:
                  BRANCH: $(Build.SourceBranchName)
                inputs:
                  workingDirectory: $(Pipeline.Workspace)/drop
                  script: |
                    set -e
                    . /opt/IBM/ace/server/bin/mqsiprofile

                    IntegrationNode=($(yq e ".IntegrationNode" config.yml))
                    ApplicationName=$(yq e ".ApplicationName" config.yml)
                    IntegrationServer=($(yq e ".IntegrationServer" config.yml))

                    broker_files=()

                    for node in "${IntegrationNode[@]}"; do
                      for broker_file in /home/devops/broker/$BRANCH/${node}*; do
                        fname=$(basename "$broker_file")
                        if [[ $fname =~ ^${node}_([0-9]+)\.broker$ ]]; then
                          broker_files+=("$broker_file")
                        fi
                      done
                    done

                    if [ ${#broker_files[@]} -eq 0 ]; then
                      echo "Error: No Integration Node found for $IntegrationNode"
                      exit 1
                    fi

                    for broker_file in "${broker_files[@]}"; do
                      servers=($(mqsilist -n "$broker_file" -w 5 | grep "running" | grep "Integration" | cut -d"'" -f2))

                      if [ ${#servers[@]} -eq 0 ]; then
                        echo "Error: Not able to access $broker_file or no Integration Server is running"
                        exit 1
                      fi

                      for server in "${IntegrationServer[@]}"; do
                        if printf '%s\n' "${servers[@]}" | grep -qx "$server"; then
                          host=$(grep host "$broker_file" | awk -F'"' '{print $4}')
                          echo "HOST: $host , IntegrationNode: $fname , IntegrationServer: $server"
                          ibmint deploy \
                            --input-bar-file "$ApplicationName.bar" \
                            --integration-node-file "$broker_file" \
                            --output-server "$server"
                        else
                            echo " Integration server $server name is incorrect or not running"
                            exit 1  
                        fi
                      done
                    done


# ================= CACHE STAGE =================
- stage: Cache
  displayName: CACHE
  pool:
    name: TFS-RH-1
  dependsOn:
    - Validation_Stage
    - Build
  condition: |
    and(
      succeeded('Validation_Stage'),
      eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.CacheFlag'], 'true'),
      or(
        eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.DeployFlag'], 'false'),
        succeeded('Build')
      ),
      ne(variables['Build.SourceBranchName'], 'main')
    )

  jobs:
    - job: Cache_Job
      displayName: CACHE UPDATE
      workspace:
        clean: all

      steps:

        - download: current
          artifact: drop

        - task: CmdLine@2
          displayName: Update cache in Database
          env:
            BRANCH: $(Build.SourceBranchName)
          inputs:
            workingDirectory: $(Pipeline.Workspace)/drop/
            script: |
              source ~/.bashrc
              set -e
              if [ ! -f config.yml ]; then
                echo "config.yml file was not found !!"
                exit 1
              fi

              mapfile -t QUERY_LIST < <(yq ".Cache[].Query" config.yml)
              QUERY_NUM=${#QUERY_LIST[@]}
              echo "Total queries to execute: $QUERY_NUM"

              for SQL in "${QUERY_LIST[@]}"; do
                echo "Queued: $SQL"
              done

              # Execute all in single session in true non-interactive mode
              OUTPUT=$(isql -v -b -n "$BRANCH" "$DB_USER" "$DB_PASS" 2>&1 <<EOF
              \noac
              $(for SQL in "${QUERY_LIST[@]}"; do echo "$SQL"; done)
              \commit
              \quit
              EOF
                )
                echo "$OUTPUT"

              FAIL_COUNT=$(echo "$OUTPUT" | grep -c "SQLRowCount returns 0")
              ERROR_COUNT=$(echo "$OUTPUT" | grep -ci "error\|ORA-\|S1000")

              if [[ $FAIL_COUNT -gt 0 ]] || [[ $ERROR_COUNT -gt 0 ]]; then
                echo "------------------------------------"
                echo "TRANSACTION FAILED — rolling back"
                echo "Queries failed : $FAIL_COUNT"
                echo "Errors found   : $ERROR_COUNT"
                isql -v -b "$BRANCH" "$DB_USER" "$DB_PASS" 2>&1 <<EOF
              \rollback
              \quit
              EOF
                exit 1
              fi

              echo "SUCCESS: All $QUERY_NUM queries committed"

        - task: CmdLine@2
          displayName: Update Cache in Server
          env:
            BRANCH: $(Build.SourceBranchName)
          inputs:
            workingDirectory: $(Pipeline.Workspace)/drop/
            script: |
              set -e

              IntegrationNode=($(yq e ".IntegrationNode" config.yml))
              broker_files=()

              for node in "${IntegrationNode[@]}"; do
                for broker_file in /home/devops/broker/$BRANCH/${node}*; do
                  fname=$(basename "$broker_file")
                  if [[ $fname =~ ^${node}_([0-9]+)\.broker$ ]]; then
                    broker_files+=("$broker_file")
                  fi
                done
              done

              if [ ${#broker_files[@]} -eq 0 ]; then
                echo "Error: No Integration Node found for $IntegrationNode"
                exit 1
              fi

              for broker_file in "${broker_files[@]}"; do
                host=$(cat "$broker_file" | grep host | cut -d"\"" -f4)
                if yq -e ".Cache" config.yml >/dev/null 2>&1; then
                  response=$(curl --connect-timeout 3 --max-time 5 -s -k -X POST http://"$host":8002/cache/v1/loadCache \
                  -H "Content-Type: application/json" \
                  -d "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" config.yml)")
                  if [[ "$response" != *'"RESPONSE":"success"'* ]]; then
                    echo "Cache load failed: $response"
                    exit 1
                  fi
                  echo "Cache load successful on $host"
                  echo "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" config.yml)"
                fi
              done
