# ============== RELEASE STAGE ==============
- stage: Release
  displayName: Deploy Stage
  pool:
    name: TFS-RH-1
  dependsOn: [Validation_Stage, Build]
  condition: |
    and(
      succeeded('Build'),
      eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.DeployFlag'], 'true'),
      ne(variables['Build.SourceBranchName'], 'main')
    )
  jobs:
    - deployment: DeployApp
      displayName: Deployment Job
      environment: $(Build.SourceBranchName)
      strategy:
        runOnce:
          deploy:
            steps:
              - download: current
                artifact: drop

              - task: CmdLine@2
                displayName: Dynamic Multi-Node Deployment
                env:
                  BRANCH: $(Build.SourceBranchName)
                inputs:
                  workingDirectory: $(Pipeline.Workspace)/drop
                  script: |
                    set -e
                    . /opt/IBM/ace/server/bin/mqsiprofile

                    # ── 1. Load Data ──────────────────────────────────────────
                    ApplicationName=$(yq e ".ApplicationName" config.yml)
                    # Convert comma-separated strings to space-separated arrays
                    NODES_RAW=$(yq e ".IntegrationNode" config.yml | tr -d ',' | sed 's/null//g')
                    SERVERS_RAW=$(yq e ".IntegrationServer // \"\"" config.yml | tr -d ',' | sed 's/null//g')

                    IFS=' ' read -r -a NODES <<< "$NODES_RAW"
                    BROKER_BASE="/home/devops/broker/$BRANCH"

                    # ── 2. Node Loop ──────────────────────────────────────────
                    for IntegrationNode in "${NODES[@]}"; do
                      echo -e "\n===================================================="
                      echo " NODE: $IntegrationNode"
                      echo "===================================================="

                      # Find .broker connection files
                      BROKER_FILES=("$BROKER_BASE"/${IntegrationNode}*.broker)
                      if [ ! -e "${BROKER_FILES[0]}" ]; then
                        echo "!! Warning: No broker connection files found for $IntegrationNode"
                        continue
                      fi

                      for broker_file in "${BROKER_FILES[@]}"; do
                        fname=$(basename "$broker_file")
                        echo "--- Connection: $fname ---"

                        # ── 3. Dynamic Discovery (The Ground Truth) ───────────
                        # Extracts only the server names from the node file
                        MQSI_DISCOVERED=$(mqsilist -n "$broker_file" | awk -F"'" '{print $2}' | grep -v '^$' | tail -n +2)
                        
                        if [ -z "$MQSI_DISCOVERED" ]; then
                          echo "!! Error: No active servers found on $fname via mqsilist."
                          exit 1
                        fi
                        mapfile -t ALL_ACTIVE_SERVERS <<< "$MQSI_DISCOVERED"

                        # ── 4. Determine Targets ──────────────────────────────
                        TARGET_SERVERS=()

                        if [ -n "$SERVERS_RAW" ]; then
                          # SCENARIO: Config has a list. We must VALIDATE before deploying.
                          echo "Logic: Manual List Provided. Validating against live node..."
                          for s in "${ALL_ACTIVE_SERVERS[@]}"; do
                            if [[ " $SERVERS_RAW " =~ " $s " ]]; then
                              TARGET_SERVERS+=("$s")
                              echo "  [VALIDATED] Server '$s' is active and in config."
                            else
                              echo "  [IGNORED]   Server '$s' is active but NOT in config."
                            fi
                          done
                        else
                          # SCENARIO: Config is empty. Deploy to everything active.
                          echo "Logic: No list provided. Deploying to ALL discovered servers..."
                          TARGET_SERVERS=("${ALL_ACTIVE_SERVERS[@]}")
                        fi

                        # ── 5. Execution ──────────────────────────────────────
                        if [ ${#TARGET_SERVERS[@]} -eq 0 ]; then
                          echo "!! Result: No servers matched the configuration for this node."
                        else
                          for server in "${TARGET_SERVERS[@]}"; do
                            echo ">>> DEPLOYING -> $server"
                            ibmint deploy \
                              --input-bar-file "$ApplicationName.bar" \
                              --integration-node-file "$broker_file" \
                              --output-server "$server"
                          done
                        fi
                      done
                    done

