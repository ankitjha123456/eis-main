                    <div class="form-group">
                        <label><i class="fa-solid fa-server"></i> SYS Service</label>
                        <input type="text" id="SYS_SERVICE" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-link"></i> SYS URL</label>
                        <input type="text" id="SYS_URL" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-clock"></i> HTTP Timeout</label>
                        <input type="text" id="HTTPTimeOut" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-shield-halved"></i> Content Check</label>
                        <input type="text" id="CONTENT_CHECK" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-gears"></i> Source Config</label>
                        <input type="text" id="SOURCE_CONFIG" />
                    </div>

                    <div class="form-group">
                        <label><i class="fa-solid fa-network-wired"></i> Third Party URL</label>
                        <input type="text" id="THIRD_PARTY_URL" />
                    </div>

                    <div class="form-group full">
                        <label><i class="fa-solid fa-hashtag"></i> Request Reference Number</label>
                        <input type="text" id="REQUEST_REFERENCE_NUMBER" />
                    </div>
                </div>

                <div class="button-area">
                    <button type="submit">
                        <i class="fa-solid fa-play"></i>
                        Generate Query
                    </button>

                    <button type="reset" class="reset">
                        <i class="fa-solid fa-rotate-left"></i>
                        Reset
                    </button>
                </div>
            </form>

            <div class="result">
                <h2>
                    <i class="fa-solid fa-file-code"></i>
                    Generated SQL
                </h2>

                <textarea id="query" rows="10"></textarea>
            </div>
        </div>

<script src="script.js"></script>

    </body>
